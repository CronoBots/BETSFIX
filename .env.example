# --- Roland Garros API configuration ---

# Base URL de la source de données gratuite (SofaScore, sans clé requise)
SOFASCORE_BASE_URL=https://api.sofascore.com/api/v1

# Identifiants "uniqueTournament" SofaScore pour Roland Garros / French Open.
# ATP (hommes) et WTA (femmes). Modifiables si SofaScore change ses IDs.
RG_ATP_TOURNAMENT_ID=2480
RG_WTA_TOURNAMENT_ID=2577

# Durée du cache en secondes (les matchs live changent vite : 30s par défaut)
CACHE_TTL_SECONDS=30

# Timeout des requêtes HTTP vers la source (secondes)
HTTP_TIMEOUT=20

# User-Agent envoyé à la source de données
HTTP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0 Safari/537.36

# --- Cotes Unibet Belgique (plateforme Kambi, offering 'ubbe') ---
UNIBET_BASE_URL=https://eu-offering-api.kambicdn.com/offering/v2018/ubbe
UNIBET_LANG=fr_BE
UNIBET_MARKET=BE
